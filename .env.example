# ============================================================
# CivicPulse — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=Divssqlpass@26
DB_NAME=civicpulse

# ─────────────────────────────────────────────────────────────
# JWT Secret — use a long random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────────────────────────
JWT_SECRET=civicpulse_super_secret_jwt_key_change_in_production

# ─────────────────────────────────────────────────────────────
# JWT Token Expiry
# Format: <number><unit>
#   s  = seconds  (e.g. 30s)
#   m  = minutes  (e.g. 15m)
#   h  = hours    (e.g. 6h, 24h)
#   d  = days     (e.g. 1d, 7d, 30d)
#
# Recommended settings:
#   Development  → 7d    (convenient, long-lived)
#   Production   → 24h   (balanced security)
#   High-security→ 1h    (short-lived, use refresh tokens)
# ─────────────────────────────────────────────────────────────
JWT_EXPIRES_IN=24h

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Frontend URL (for CORS — change to your actual frontend origin)
CLIENT_URL=http://localhost:3000
