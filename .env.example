# ============================================================
# CivicPulse — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=Divssqlpass@26
DB_NAME=civicpulse

# JWT Secret (use a long random string in production)
JWT_SECRET=civicpulse_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000
